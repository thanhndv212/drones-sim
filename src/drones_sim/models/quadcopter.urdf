<?xml version="1.0" encoding="UTF-8"?>
<robot name="quadcopter">

  <!-- ============================================================
       Quadcopter URDF — X-configuration
       Physical params match QuadcopterDynamics defaults:
         mass=1.0 kg, arm_length=0.2 m,
         inertia=diag(0.01, 0.01, 0.018) kg·m²
       Motor layout (top view):
           1 (front, +X)
       4 (left, -Y)   2 (right, +Y)
           3 (back, -X)
       ============================================================ -->

  <!-- ======================== Materials ======================== -->
  <material name="blue">
    <color rgba="0.196 0.196 0.784 1.0"/>
  </material>
  <material name="red">
    <color rgba="1.0 0.196 0.196 1.0"/>
  </material>
  <material name="green">
    <color rgba="0.196 0.784 0.196 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.392 0.392 0.392 1.0"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.25 0.25 0.25 1.0"/>
  </material>

  <!-- ======================== Base Link ======================== -->
  <link name="base_link">
    <inertial>
      <mass value="0.6"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0006" ixy="0" ixz="0"
               iyy="0.0006" iyz="0"
               izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.04"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.04"/>
      </geometry>
    </collision>
  </link>

  <!-- ======================== Arm 1 (Front, +X) ================ -->
  <link name="arm_1">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0.05 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.00005" iyz="0"
               izz="0.00005"/>
    </inertial>
    <visual>
      <origin xyz="0.05 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.1"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0.05 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.1"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_to_arm_1" type="fixed">
    <parent link="base_link"/>
    <child link="arm_1"/>
    <origin xyz="0.05 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ======================== Arm 2 (Right, +Y) ================ -->
  <link name="arm_2">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0.05 0" rpy="0 0 0"/>
      <inertia ixx="0.00005" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.00005"/>
    </inertial>
    <visual>
      <origin xyz="0 0.05 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.1"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <origin xyz="0 0.05 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.1"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_to_arm_2" type="fixed">
    <parent link="base_link"/>
    <child link="arm_2"/>
    <origin xyz="0 0.05 0" rpy="0 0 0"/>
  </joint>

  <!-- ======================== Arm 3 (Back, -X) ================= -->
  <link name="arm_3">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="-0.05 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.00005" iyz="0"
               izz="0.00005"/>
    </inertial>
    <visual>
      <origin xyz="-0.05 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.1"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="-0.05 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.1"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_to_arm_3" type="fixed">
    <parent link="base_link"/>
    <child link="arm_3"/>
    <origin xyz="-0.05 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ======================== Arm 4 (Left, -Y) ================= -->
  <link name="arm_4">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 -0.05 0" rpy="0 0 0"/>
      <inertia ixx="0.00005" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.00005"/>
    </inertial>
    <visual>
      <origin xyz="0 -0.05 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.1"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 -0.05 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.1"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_to_arm_4" type="fixed">
    <parent link="base_link"/>
    <child link="arm_4"/>
    <origin xyz="0 -0.05 0" rpy="0 0 0"/>
  </joint>

  <!-- ======================== Rotor 1 (Front, +X) ============== -->
  <link name="rotor_1">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000045" ixy="0" ixz="0"
               iyy="0.000045" iyz="0"
               izz="0.00009"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.005"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.005"/>
      </geometry>
    </collision>
  </link>

  <joint name="arm_1_to_rotor_1" type="fixed">
    <parent link="arm_1"/>
    <child link="rotor_1"/>
    <origin xyz="0.1 0 0.01" rpy="0 0 0"/>
  </joint>

  <!-- ======================== Rotor 2 (Right, +Y) ============== -->
  <link name="rotor_2">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000045" ixy="0" ixz="0"
               iyy="0.000045" iyz="0"
               izz="0.00009"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.005"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.005"/>
      </geometry>
    </collision>
  </link>

  <joint name="arm_2_to_rotor_2" type="fixed">
    <parent link="arm_2"/>
    <child link="rotor_2"/>
    <origin xyz="0 0.1 0.01" rpy="0 0 0"/>
  </joint>

  <!-- ======================== Rotor 3 (Back, -X) =============== -->
  <link name="rotor_3">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000045" ixy="0" ixz="0"
               iyy="0.000045" iyz="0"
               izz="0.00009"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.005"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.005"/>
      </geometry>
    </collision>
  </link>

  <joint name="arm_3_to_rotor_3" type="fixed">
    <parent link="arm_3"/>
    <child link="rotor_3"/>
    <origin xyz="-0.1 0 0.01" rpy="0 0 0"/>
  </joint>

  <!-- ======================== Rotor 4 (Left, -Y) =============== -->
  <link name="rotor_4">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000045" ixy="0" ixz="0"
               iyy="0.000045" iyz="0"
               izz="0.00009"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.005"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.005"/>
      </geometry>
    </collision>
  </link>

  <joint name="arm_4_to_rotor_4" type="fixed">
    <parent link="arm_4"/>
    <child link="rotor_4"/>
    <origin xyz="0 -0.1 0.01" rpy="0 0 0"/>
  </joint>

</robot>
